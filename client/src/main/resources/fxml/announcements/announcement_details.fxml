<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ser460.sundevilconnect.client.announcements.AnnouncementDetailsView"
      fx:id="root"
      spacing="8.0">

  <padding>
    <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
  </padding>

  <HBox>
    <Label text="Announcement Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <Region HBox.hgrow="ALWAYS" />
    <Button fx:id="flagButton" text="Flag" onAction="#handleFlag" />
  </HBox>

  <HBox spacing="20">
    <Label text="Title:"/>
    <Label fx:id="titleLabel"/>
    <Label text="Club:"/>
    <Label fx:id="clubLabel"/>
    <Label text="Posted By:"/>
    <Label fx:id="postedByLabel"/>
    <Label text="Date:"/>
    <Label fx:id="dateLabel"/>
  </HBox>

  <TextArea fx:id="bodyArea" wrapText="true" editable="false" prefRowCount="4" VBox.vgrow="ALWAYS"/>

</VBox>