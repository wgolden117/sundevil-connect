<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ser460.sundevilconnect.client.admin.AdminPanel">

  <HBox VBox.vgrow="ALWAYS">

    <!-- Sidebar -->
    <VBox minWidth="150.0" prefWidth="160.0" spacing="8.0">
      <padding>
        <Insets bottom="16.0" left="12.0" right="12.0" top="16.0"/>
      </padding>

      <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Admin Panel"/>

      <Separator/>

      <Button maxWidth="Infinity" onAction="#onClubsClicked" prefHeight="50.0" text="Club Approvals"/>
      <Button maxWidth="Infinity" onAction="#onContentClicked" prefHeight="50.0" text="Flagged Content"/>
    </VBox>

    <!-- Content Area -->
    <AnchorPane fx:id="contentArea" HBox.hgrow="ALWAYS"/>

  </HBox>
</VBox>
