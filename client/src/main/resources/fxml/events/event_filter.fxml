<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ser460.sundevilconnect.client.events.EventFilterPanel"
            prefHeight="500.0" prefWidth="250.0">

    <VBox spacing="12"
          layoutX="10"
          layoutY="10"
          prefWidth="230">

        <Label text="Filters"
               style="-fx-font-size: 14px; -fx-font-weight: bold;" />

        <!-- Category -->
        <Label text="Category:" />
        <ComboBox fx:id="categoryDropdown" prefWidth="200"/>

        <!-- Club -->
        <Label text="Club:" />
        <ComboBox fx:id="clubDropdown" prefWidth="200"/>

        <!-- Date Range -->
        <Label text="From Date:" />
        <DatePicker fx:id="fromDatePicker" prefWidth="200"/>

        <Label text="To Date:" />
        <DatePicker fx:id="toDatePicker" prefWidth="200"/>

        <!-- Paid -->
        <CheckBox fx:id="paidCheckbox" text="Paid Events Only" />

        <!-- Apply button -->
        <Button text="Apply Filters"
                onAction="#handleApplyFilters"
                prefWidth="200"/>

        <!-- Clear button -->
        <Button text="Clear Filters"
                onAction="#handleClearFilters"
                prefWidth="200"/>

    </VBox>

</AnchorPane>