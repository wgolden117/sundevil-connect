<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ser460.sundevilconnect.client.events.EventDetailsView"
            prefHeight="120.0" prefWidth="600.0">

    <VBox spacing="10"
          layoutX="10"
          layoutY="10"
          prefWidth="580">

        <Label text="Event Details"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />

        <HBox spacing="20">

            <Label text="Title:" />
            <Label fx:id="titleLabel" />

            <Label text="Category:" />
            <Label fx:id="categoryLabel" />

            <Label text="Location:" />
            <Label fx:id="locationLabel" />

            <Label text="Date:" />
            <Label fx:id="dateLabel" />

        </HBox>

        <Button fx:id="registerButton"
                text="Register"
                onAction="#handleRegister" />

    </VBox>

</AnchorPane>