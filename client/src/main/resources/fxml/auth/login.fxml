<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ser460.sundevilconnect.client.auth.LoginPage">
  <VBox alignment="CENTER" spacing="25.0">
    <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <GridPane hgap="10.0" vgap="15.0">
      <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="170.0" minWidth="10.0" prefWidth="99.0" />
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="258.0" minWidth="10.0" prefWidth="251.0" />
      </columnConstraints>
      <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
      </rowConstraints>
      <Label text="Email:" />
      <TextField fx:id="emailField" alignment="CENTER" prefHeight="30.0" promptText="Email" GridPane.columnIndex="1" />
      <Label text="Password:" GridPane.rowIndex="1" />
      <PasswordField fx:id="passwordField" alignment="CENTER" prefHeight="30.0" promptText="Password" GridPane.columnIndex="1" GridPane.rowIndex="1" />
    </GridPane>
      <Label fx:id="errorLabel" alignment="CENTER" minHeight="20.0" minWidth="300.0" text="Error!" textFill="#ff3939" />
    <Button alignment="CENTER" mnemonicParsing="false" onAction="#handleLoginButton" prefHeight="40.0" prefWidth="100.0" text="Login" textAlignment="CENTER" />
  </VBox>
</AnchorPane>
