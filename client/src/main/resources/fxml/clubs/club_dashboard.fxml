<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ser460.sundevilconnect.client.clubs.ClubDashboard"
      fx:id="root"
      VBox.vgrow="ALWAYS">

  <HBox VBox.vgrow="ALWAYS">

    <!-- Sidebar -->
    <VBox prefWidth="200.0" minWidth="200.0" maxWidth="200.0" spacing="8.0">
      <padding>
        <Insets top="16.0" right="12.0" bottom="16.0" left="12.0"/>
      </padding>

      <Label fx:id="clubNameLabel" text="Club Name" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-wrap-text: true;"/>

      <Separator/>

      <Button fx:id="requestsButton" text="Membership Requests" maxWidth="Infinity"
              onAction="#onRequestsClicked"/>
      <Button fx:id="eventsButton" text="Events" maxWidth="Infinity"
              onAction="#onEventsClicked"/>
      <Button fx:id="announcementsButton" text="Announcements" maxWidth="Infinity"
              onAction="#onAnnouncementsClicked"/>
    </VBox>

    <!-- Content Area -->
    <AnchorPane fx:id="contentArea" HBox.hgrow="ALWAYS"/>

  </HBox>
</VBox>