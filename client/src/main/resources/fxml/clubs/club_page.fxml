<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ser460.sundevilconnect.client.clubs.ClubPageView">
  <padding>
    <Insets bottom="10" left="10" right="10" top="10" />
  </padding>

  <!-- Club Header -->
  <HBox>
    <Label fx:id="clubNameLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
    <Region HBox.hgrow="ALWAYS" />
    <Button fx:id="manageClubButton" onAction="#onManageClubClicked" text="Manage Club" visible="false">
         <HBox.margin>
            <Insets top="5.0" />
         </HBox.margin></Button>
  </HBox>

  <!-- Main Info -->
  <VBox spacing="6">
    <HBox spacing="10">
      <Label text="Category:" />
      <Label fx:id="categoryLabel" prefWidth="100" />
      <Label text="Founded:" />
      <Label fx:id="foundedDateLabel" prefWidth="80" />
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="joinButton" disable="true" onAction="#handleJoinClub" prefWidth="90.0" text="Loading..." />
    </HBox>
    <Label fx:id="descriptionLabel" prefHeight="35.0" wrapText="true" />
  </VBox>

  <!-- Two Column Section -->
  <HBox spacing="10" VBox.vgrow="ALWAYS">

    <!-- Announcements -->
    <VBox spacing="6" HBox.hgrow="ALWAYS">
      <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Announcements" />
      <ListView fx:id="announcementsListView" VBox.vgrow="ALWAYS" />
    </VBox>

    <!-- Events -->
    <VBox prefWidth="200" spacing="6">
      <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Events" />
      <ListView fx:id="eventsListView" VBox.vgrow="ALWAYS" />
    </VBox>

  </HBox>

</VBox>
