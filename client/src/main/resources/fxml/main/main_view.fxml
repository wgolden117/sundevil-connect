<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ser460.sundevilconnect.client.main.MainController">

    <!-- Top header -->
    <top>
        <HBox spacing="10" style="-fx-padding: 10;">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="SunDevil Connect" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="nameLabel" prefHeight="27.0" text="Role: UNKNOWN" />
        </HBox>
    </top>

    <!-- Main content -->
    <center>
        <TabPane fx:id="mainTabPane">

            <tabs>

                <!-- STUDENT: EVENTS TAB -->
                <Tab fx:id="eventsTab" closable="false" text="Events">
                    <AnchorPane fx:id="eventsPane" />
                </Tab>

                <!-- STUDENT: MY EVENTS TAB -->
                <Tab fx:id="myEventsTab" closable="false" text="My Events">
                    <AnchorPane fx:id="myEventsPane" />
                </Tab>

                <!-- STUDENT: CLUBS TAB -->
                <Tab fx:id="clubsTab" closable="false" text="Club Browser">
                    <AnchorPane fx:id="clubsPane" />
                </Tab>

                <!-- STUDENT: MY CLUBS TAB -->
                <Tab fx:id="myClubsTab" closable="false" text="My Clubs">
                    <AnchorPane fx:id="myClubsPane" />
                </Tab>

                <!-- CLUB LEADER: CREATE EVENTS -->
                <Tab fx:id="createEventTab" closable="false" text="Create/Manage Events">
                    <AnchorPane>
                        <Label text="Create/Manage Events coming soon..." AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0" />
                    </AnchorPane>
                </Tab>

                <!-- CLUB LEADER: APPROVE MEMBERS -->
                <Tab fx:id="approveMembersTab" closable="false" text="Approve Members">
                    <AnchorPane>
                        <Label text="Approve Members coming soon..." AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0" />
                    </AnchorPane>
                </Tab>

                <!-- CLUB LEADER: POST UPDATES -->
                <Tab fx:id="postUpdatesTab" closable="false" text="Post Updates">
                    <AnchorPane>
                        <Label text="Post Updates coming soon..." AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0" />
                    </AnchorPane>
                </Tab>

                <!-- ADMIN: MANAGE CLUBS -->
                <Tab fx:id="manageClubsTab" closable="false" text="Manage Clubs">
                    <AnchorPane>
                        <Label text="Manage Clubs coming soon..." AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0" />
                    </AnchorPane>
                </Tab>

                <!-- ADMIN: APPROVE CLUBS -->
                <Tab fx:id="approveClubsTab" closable="false" text="Approve Clubs">
                    <AnchorPane>
                        <Label text="Approve Clubs coming soon..." AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0" />
                    </AnchorPane>
                </Tab>

                <!-- ADMIN: FLAGGED CONTENT -->
                <Tab fx:id="flaggedContentTab" closable="false" text="Flagged Content">
                    <AnchorPane>
                        <Label text="Flagged content management coming soon..." AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0" />
                    </AnchorPane>
                </Tab>

            </tabs>

        </TabPane>
    </center>
   <bottom>
      <ButtonBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <buttons>
          <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#handleLogout" text="Log Out" />
        </buttons>
         <BorderPane.margin>
            <Insets left="10.0" right="10.0" />
         </BorderPane.margin>
      </ButtonBar>
   </bottom>

</BorderPane>
